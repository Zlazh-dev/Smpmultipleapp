# ── PostgreSQL (Portal + TU shared) ──
POSTGRES_USER=smpit
POSTGRES_PASSWORD=smpit_secret_2024

# ── MySQL (RADIG) ──
MYSQL_ROOT_PASSWORD=mysql_root_2024
MYSQL_RADIG_USER=radig
MYSQL_RADIG_PASSWORD=radig_secret_2024

# ── Auth ──
NEXTAUTH_SECRET=change-this-to-a-random-64-char-string
SSO_JWT_SECRET=change-this-to-a-different-random-string

# ── TU App ──
TU_DEFAULT_PASSWORD=Asysyadzili2025!

# ── URLs (local development) ──
PORTAL_URL=http://portal.localhost
TU_URL=http://tu.localhost
RADIG_URL=http://radig.localhost
GURU_URL=http://guru.localhost
WALI_URL=http://wali.localhost

