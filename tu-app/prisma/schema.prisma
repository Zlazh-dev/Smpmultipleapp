generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccessLevel {
  KHUSUS
  UMUM
}

enum PresensiStatus {
  HADIR
  IZIN
  ALFA
  SAKIT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DokumenKategori {
  SK
  SERTIFIKAT
  PRIBADI
  SURAT
}

model Pegawai {
  id             String     @id @default(cuid())
  nip            String     @unique
  namaLengkap    String
  jabatan        String
  accessLevel    AccessLevel @default(UMUM) @map("role")
  username       String     @unique
  portalUserId   String?    @unique  // Links to Portal User.id (centralized identity)
  noHp           String?
  alamat         String?
  faceDescriptor Float[]    // 128-dim face descriptor vector for face recognition
  facePhoto      String?    // Path to uploaded face photo for admin review
  faceVerified   Boolean    @default(false) // Admin has verified the face photo
  skRiwayat      Json[]     // [{"noSK":"123/KS/2026","tanggal":"2026-01-01","jenis":"Pengangkatan"}]
  kinerja        Json?      // e-Kinerja scores
  presensi       Presensi[]
  cuti           Cuti[]
  dokumen        Dokumen[]
  folders        EfilingFolder[]
  
  // New CQRS Relations
  attendanceRawEvents      AttendanceRawEvent[]
  dailyAttendanceSummaries DailyAttendanceSummary[]
  performedAuditLogs       AttendanceAuditLog[]
  faceEnrollment           FaceEnrollment?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([nip])
  @@index([jabatan])
  @@index([portalUserId])
}

model Presensi {
  id         String         @id @default(cuid())
  pegawaiId  String
  tanggal    DateTime
  status     PresensiStatus
  bukti      String?        // QR/photo URL
  keterangan String?
  jamDatang  DateTime?      // Check-in time
  jamPulang  DateTime?      // Check-out time
  pegawai    Pegawai        @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([pegawaiId, tanggal])
  @@index([tanggal])
}

// ==========================================
// CQRS ATTENDANCE MODELS (Revised)
// ==========================================

enum AttendanceStatus {
  HADIR
  IZIN
  SAKIT
  ALFA
  LIBUR
}

enum AttendanceEventType {
  IN
  OUT
}

enum FaceEnrollmentStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

/// How the final daily status was resolved
enum ResolutionSource {
  RAW_EVENT        // Derived from check-in/out events
  LEAVE_APPROVAL   // Derived from approved Cuti record
  AUTO_ABSENT      // System marked ALFA (no event, working day)
  MANUAL_OVERRIDE  // Admin changed status manually
  SYSTEM_RECOMPUTE // System recalculated from raw data
  CALENDAR         // Non-working day / holiday
}

enum AuditActionType {
  MANUAL_OVERRIDE
  SYSTEM_RECOMPUTE
}

/// Immutable log of a single check-in or check-out physical action.
/// Never updated or deleted — append-only for audit integrity.
/// The unique constraint on [pegawaiId, eventType, occurredAt] prevents
/// duplicate events from retry-safe ingestion (idempotency guard).
model AttendanceRawEvent {
  id                 String              @id @default(cuid())
  pegawaiId          String
  eventType          AttendanceEventType
  occurredAt         DateTime            // UTC moment of the physical event
  latitude           Float?
  longitude          Float?
  isWithinGeofence   Boolean?            // null = not checked, true/false = result
  verificationMethod String?             // "gps", "face", "qr", "manual"
  faceVerified       Boolean?            // null = not attempted, true/false = result
  sourceRef          String?             // Device/session identifier for tracing
  bukti              String?             // Photo/QR URL
  keterangan         String?
  createdAt          DateTime            @default(now())

  pegawai            Pegawai             @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)

  @@unique([pegawaiId, eventType, occurredAt]) // Idempotency guard
  @@index([pegawaiId, occurredAt])
  @@index([occurredAt])
}

/// The resolved daily attendance outcome — one row per employee per calendar date.
/// Created live (unfinalized), locked by the EOD finalization job.
model DailyAttendanceSummary {
  id               String           @id @default(cuid())
  pegawaiId        String
  date             DateTime         @db.Date   // Business date (date-only, no time component)
  status           AttendanceStatus
  resolutionSource ResolutionSource            // Explains HOW this status was determined
  checkInTime      DateTime?                   // UTC timestamp of first IN event
  checkOutTime     DateTime?                   // UTC timestamp of last OUT event
  isFinalized      Boolean          @default(false)
  finalizedAt      DateTime?                   // UTC moment when finalization locked this record
  keterangan       String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  pegawai          Pegawai                     @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)
  auditLogs        AttendanceAuditLog[]

  @@unique([pegawaiId, date])
  @@index([date])
  @@index([status])
  @@index([isFinalized])
}

/// EXCEPTION-ONLY calendar for holidays and special non-working days.
/// This is NOT a full calendar. If a date is NOT in this table, the resolution
/// engine falls back to GeofenceSettings.hariKerja (default: Mon-Fri).
/// Only dates that OVERRIDE the default weekly pattern need entries here.
model WorkingDayCalendar {
  id           String   @id @default(cuid())
  date         DateTime @unique @db.Date  // Business date
  isWorkingDay Boolean  @default(false)   // false = holiday; true = special working day (e.g. Saturday event)
  description  String?                    // e.g. "Libur Nasional", "Hari Raya", "Sabtu Kerja"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Append-only ledger of all manual overrides and system recomputes
/// on finalized DailyAttendanceSummary records.
model AttendanceAuditLog {
  id                 String                 @id @default(cuid())
  summaryId          String
  performedByAdminId String                 // Pegawai.id of the KHUSUS admin who did it
  previousStatus     AttendanceStatus
  newStatus          AttendanceStatus
  actionType         AuditActionType
  reason             String                 // Mandatory justification
  notes              String?                // Free-text additional context
  metadata           Json?                  // Structured context (e.g. original event IDs, cuti ref)
  createdAt          DateTime               @default(now())

  summary            DailyAttendanceSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  performedBy        Pegawai                @relation(fields: [performedByAdminId], references: [id])

  @@index([summaryId])
  @@index([performedByAdminId])
  @@index([createdAt])
}
// ==========================================

model Cuti {
  id             String         @id @default(cuid())
  pegawaiId      String
  jenisCuti      String         // Tahunan/Sakit/Melahirkan
  tanggalMulai   DateTime
  tanggalSelesai DateTime
  lamaHari       Int
  alasan         String
  status         ApprovalStatus @default(PENDING)
  approverTu     String?
  approverKs     String?
  dokBukti       String?        // Upload bukti
  pegawai        Pegawai        @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([pegawaiId])
  @@index([status])
  @@index([pegawaiId, tanggalMulai, tanggalSelesai]) // Resolution engine date-range lookups
}

model Dokumen {
  id         String          @id @default(cuid())
  pegawaiId  String?
  folderId   String?         // e-Filing folder reference
  kategori   DokumenKategori
  namaAsli   String
  namaFile   String          // S3 key
  ukuran     Int             // bytes
  mimeType   String
  pathS3     String
  uploadedBy String
  pegawai    Pegawai?        @relation(fields: [pegawaiId], references: [id], onDelete: SetNull)
  folder     EfilingFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt  DateTime        @default(now())

  @@index([kategori])
  @@index([pegawaiId])
  @@index([folderId])
}

model EfilingFolder {
  id         String          @id @default(cuid())
  nama       String
  parentId   String?
  pegawaiId  String          // Owner (the guru/pegawai)
  parent     EfilingFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   EfilingFolder[] @relation("FolderTree")
  dokumen    Dokumen[]
  pegawai    Pegawai         @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([pegawaiId])
  @@index([parentId])
}

enum TemplateCategory {
  SURAT_IZIN
  LAPORAN_KEHADIRAN
  SK
  SURAT_TUGAS
  CUSTOM
}

model PrintTemplate {
  id         String           @id @default(cuid())
  nama       String
  kategori   TemplateCategory
  deskripsi  String?
  canvasData Json             // Full editor state (elements, dimensions, etc.)
  isActive   Boolean          @default(false) // Only one active per category
  createdBy  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([kategori])
}

model GeofenceSettings {
  id         String   @id @default("default")
  latitude   Float    @default(-7.2575)   // Default: approximate school location
  longitude  Float    @default(112.7521)
  radius     Int      @default(200)       // meters
  namaLokasi String   @default("SMPIT Asy-Syadzili")
  jamMasuk   String   @default("07:00")
  jamPulang  String   @default("16:00")
  hariKerja  String[] @default(["Senin", "Selasa", "Rabu", "Kamis", "Jumat"])
  isActive   Boolean  @default(true)
  updatedAt  DateTime @updatedAt
}

model ProfilSekolah {
  id              String   @id @default("default")
  namaSekolah     String   @default("SMPIT Asy-Syadzili")
  npsn            String   @default("")
  alamat          String   @default("")
  kelurahan       String   @default("")
  kecamatan       String   @default("")
  kabupaten       String   @default("")
  provinsi        String   @default("")
  kodePos         String   @default("")
  telepon         String   @default("")
  email           String   @default("")
  website         String   @default("")
  statusSekolah   String   @default("Swasta")     // Negeri / Swasta
  tahunBerdiri    String   @default("")
  akreditasi      String   @default("")            // A / B / C / Belum
  namaKepalaSekolah String @default("")
  nipKepalaSekolah  String @default("")
  latitude        Float    @default(-7.2575)
  longitude       Float    @default(112.7521)
  logo            String?                          // Base64 or file path
  updatedAt       DateTime @updatedAt
}

model FaceEnrollment {
  id               String               @id @default(cuid())
  pegawaiId        String               @unique
  status           FaceEnrollmentStatus
  approvedPhotoUrl String?              // File path (e.g. "uploads/faces/xxx_approved.jpg")
  pendingPhotoUrl  String?              // File path (e.g. "uploads/faces/xxx_pending.jpg")
  faceDescriptor   Float[]              // 128-dim descriptor submitted with the photo
  rejectionReason  String?
  reviewedBy       String?
  submittedAt      DateTime             @default(now())
  approvedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  pegawai          Pegawai              @relation(fields: [pegawaiId], references: [id], onDelete: Cascade)

  @@index([status])
}
